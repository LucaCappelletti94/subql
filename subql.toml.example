# SubQL Configuration Example
# Copy this file to subql.toml and customize as needed

# Storage directory for durable shards
# This directory will be created if it doesn't exist
storage_path = "/var/lib/subql/shards"

# Rotate shard when it exceeds this size (bytes)
# Default: 10485760 (10 MB)
rotation_threshold = 10485760

# Merge configuration
[merge]
# Trigger merge when shard count exceeds this threshold
# Default: 5
shard_threshold = 5

# Background merge interval (seconds)
# Default: 3600 (1 hour)
interval_secs = 3600

# Schema catalog configuration
[catalog]
# Database URL for schema introspection
# Examples:
#   PostgreSQL: "postgresql://user:pass@localhost:5432/mydb"
#   MySQL:      "mysql://user:pass@localhost:3306/mydb"
#   SQLite:     "sqlite://path/to/db.sqlite"
database_url = "postgresql://localhost/mydb"

# SQL dialect: "postgres", "mysql", or "sqlite"
# Default: "postgres"
dialect = "postgres"
